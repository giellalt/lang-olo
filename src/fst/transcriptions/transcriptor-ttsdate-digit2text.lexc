! ================================== !
!      The Livvi Karelian dates      !
! ================================== !

! pakkaskuu 1
! tuhukuu 2
! kevätkuu 3
! sulakuu 4
! oraskuu 5
! kezäkuu 6
! heinykuu 7
! elokuu 8
! syvyskuu 9
! ligakuu 10
! kylmykuu 11
! talvikuu 12

! 12.8.
! kahtestostu päivy elokuudu
! 12. elokuudu

Multichar_Symbols

@U.MONTH.1@ 
@U.MONTH.2@ 
@U.MONTH.3@ 
